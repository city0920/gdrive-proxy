{
  "version": 2,
  "name": "gdrive-proxy",
  "rewrites": [
    {
      "source": "/drive/:path*",
      "destination": "/api/gdrive"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "/api/gdrive"
    },
    {
      "source": "/(.*)",
      "destination": "/api/gdrive"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
